{
  "name": "michinomicon",
  "version": "1.0.0",
  "description": "Michinomicon Website PayloadCMS",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "build:clean": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:clean": "cross-env NODE_OPTIONS=--no-deprecation--inspect rm -rf .next && next build && pnpm dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "backup": "scripts/db-backup.sh",
    "restore": "scripts/db-restore.sh"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.76.1",
    "@payloadcms/db-mongodb": "3.76.1",
    "@payloadcms/email-nodemailer": "3.76.1",
    "@payloadcms/live-preview-react": "3.76.1",
    "@payloadcms/next": "3.76.1",
    "@payloadcms/payload-cloud": "3.76.1",
    "@payloadcms/plugin-form-builder": "3.76.1",
    "@payloadcms/plugin-nested-docs": "3.76.1",
    "@payloadcms/plugin-redirects": "3.76.1",
    "@payloadcms/plugin-search": "3.76.1",
    "@payloadcms/plugin-seo": "3.76.1",
    "@payloadcms/richtext-lexical": "3.76.1",
    "@payloadcms/ui": "3.76.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "10.1.0",
    "dotenv": "17.2.4",
    "flipbook-js": "^1.1.1",
    "geist": "^1.7.0",
    "graphql": "^16.12.0",
    "lucide-react": "^0.563.0",
    "next": "15.4.11",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "nodemailer": "8.0.1",
    "payload": "3.76.1",
    "pdf-img-convert": "^2.0.0",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.1",
    "react-pageflip": "^2.0.3",
    "react-pdf": "^9.0.0",
    "sharp": "0.34.5",
    "tailwind-merge": "3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.2",
    "@types/escape-html": "^1.0.4",
    "@types/node": "25.0.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "5.1.4",
    "autoprefixer": "^10.4.24",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "jsdom": "28.0.0",
    "playwright": "1.58.2",
    "playwright-core": "1.58.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^22",
    "pnpm": "^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "pdfjs-dist": "4.4.168"
    }
  },
  "resolutions": {
    "pdfjs-dist": "4.4.168"
  }
}
